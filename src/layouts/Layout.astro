---
import '../styles/global.css'; 
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>Astro Basics</title>
  </head>
  <body>
    <div id="scroll-bg"></div>
    <div id="diamond-grid"></div>

    <main id="main-content">
      <slot />
    </main>

    <script is:inline>
      const bg = document.getElementById('scroll-bg');

      function handleScroll(e) {
        const container = e.target;
        const maxScroll = container.scrollHeight - container.clientHeight;
        if (maxScroll <= 0) return; 
        
        const scrollPercent = container.scrollTop / maxScroll;

        const hueShift = Math.floor(scrollPercent * 80); 
        bg.style.background = `linear-gradient(${135 + (scrollPercent * 45)}deg, hsl(${240 + hueShift}, 47%, 20%) 0%, hsl(${222 - hueShift}, 47%, 10%) 100%)`;

        const moveY = scrollPercent * -20; 
        const scale = 1 + (scrollPercent * 0.05); 
        bg.style.transform = `translateY(${moveY}px) scale(${scale})`;
      }

      document.querySelectorAll('.screen-view').forEach(panel => {
        panel.addEventListener('scroll', handleScroll);
      });
    </script>
  </body>
</html>