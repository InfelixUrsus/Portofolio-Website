---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

import { globalTranslations } from '../utils/translations';
const localProjects = await getCollection('projects');
const t = globalTranslations.en;
---

<Layout>
  <div class="top-nav-controls">
    <button id="global-lang-btn" class="nav-btn">{t.btnText}</button>
    <a href="/admin" id="admin-portal-link" aria-label="Admin Panel">
      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="3"></circle>
        <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"></path>
      </svg>
    </a>
  </div>

  <button id="view-toggle-btn" class="pointing-right" aria-label="Switch Page">
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="15 18 9 12 15 6"></polyline>
    </svg>
  </button>

  <div id="side-label-right" class="side-label">{t.labelRight}</div>
  <div id="side-label-left" class="side-label" style="display: none; opacity: 0;">{t.labelLeft}</div>

  <div class="slider-window">
    <div class="slider-track" id="main-track">
      
      <section class="screen-view">
        <div class="content-wrapper">
          <h1 id="portfolio-title">{t.title}</h1>          
          <div class="bio-card">
            <h2 id="about-heading">{t.aboutHeading}</h2>
            <p id="about-intro">{t.aboutIntro}</p>

            <p>
              <strong id="sys-title">{t.sysTitle}</strong><br />
              <span id="sys-desc">{t.sysDesc}</span>
            </p>

            <p>
              <strong id="web-title">{t.webTitle}</strong><br />
              <span id="web-desc">{t.webDesc}</span>
            </p>

            <p>
              <strong id="data-title">{t.dataTitle}</strong><br />
              <span id="data-desc">{t.dataDesc}</span>
            </p>

            <hr style="margin: 2rem 0 1.5rem 0; border: 0; border-top: 1px solid rgba(255,255,255,0.1);" />
            <h3 id="skills-heading" class="skills-main-title">{t.skillsHeading}</h3>
            
            <div class="skills-display-grid">
              <div class="skill-item-card">
                <svg viewBox="0 0 24 24" class="skill-icon" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 15c-2.76 0-5-2.24-5-5s2.24-5 5-5c1.65 0 3.1.81 4 2.06l-1.9 1.14C13.65 9.53 12.91 9 12 9c-1.66 0-3 1.34-3 3s1.34 3 3 3c.91 0 1.65-.53 2.1-1.2l1.9 1.14c-.9 1.25-2.35 2.06-4 2.06z"/></svg>
                <span>C</span>
              </div>
              <div class="skill-item-card">
                <svg viewBox="0 0 24 24" class="skill-icon" fill="currentColor"><path d="M11.5 2C6.25 2 2 6.25 2 11.5S6.25 21 11.5 21s9.5-4.25 9.5-9.5S16.75 2 11.5 2zm0 14c-2.48 0-4.5-2.02-4.5-4.5S9.02 7 11.5 7c1.48 0 2.79.73 3.6 1.85l-1.71 1.03C12.98 9.38 12.3 9 11.5 9c-1.38 0-2.5 1.12-2.5 2.5s1.12 2.5 2.5 2.5c.8 0 1.48-.38 1.89-.88l1.71 1.03c-.81 1.12-2.12 1.85-3.6 1.85zm6.5-4h-1.5v1.5h-1V12h-1.5v-1h1.5V9.5h1V11H18v1zm4 0h-1.5v1.5h-1V12h-1.5v-1h1.5V9.5h1V11H22v1z"/></svg>
                <span>C++</span>
              </div>
              <div class="skill-item-card">
                <svg viewBox="0 0 24 24" class="skill-icon" fill="currentColor"><path d="M12.003 2c-2.72 0-2.54 1.176-2.54 1.176h2.576v.368H7.3c0 0-1.792.174-1.792 2.542 0 2.366 1.47 2.49 1.47 2.49h.884V7.324c0-1.12.91-2.03 2.03-2.03h4.154c1.12 0 1.967-.84 1.967-1.967 0-1.12-.847-1.327-1.967-1.327H12.003zm-.006 20c2.72 0 2.54-1.176 2.54-1.176H11.96v-.368H16.7c0 0 1.792-.174 1.792-2.542 0-2.366-1.47-2.49-1.47-2.49h-.884v1.252c0 1.12-.91 2.03-2.03 2.03H9.954c-1.12 0-1.967.84-1.967 1.967 0 1.12.847 1.327 1.967 1.327h2.042zM9.5 5.5a.75.75 0 1 1 0-1.5.75.75 0 0 1 0 1.5zm5 13a.75.75 0 1 1 0-1.5.75.75 0 0 1 0 1.5z"/></svg>
                <span>Python</span>
              </div>
              <div class="skill-item-card">
                <svg viewBox="0 0 24 24" class="skill-icon" fill="currentColor"><path d="M2 21h16v-2H2v2zM18.5 7C17 7 15.5 8 14.5 9.5c-1-1.5-2.5-2.5-4-2.5-.7 0-1.5.2-2 .5V2h-2v7.5c-1.1.8-2 2-2 3.5 0 2.8 2.2 5 5 5h4c2.8 0 5-2.2 5-5 0-1-.3-2-.9-2.8l1.4-1.4c.6.5 1.4.7 2.1.7 1.9 0 3.4-1.5 3.4-3.4S20.4 7 18.5 7zm-5.5 6c0 1.7-1.3 3-3 3h-2c-1.7 0-3-1.3-3-3s1.3-3 3-3h2c1.7 0 3 1.3 3 3zm5.5-2.6c-.8 0-1.4-.6-1.4-1.4s.6-1.4 1.4-1.4 1.4.6 1.4 1.4-.6 1.4-1.4 1.4z"/></svg>
                <span>Java</span>
              </div>
              <div class="skill-item-card">
                <svg viewBox="0 0 24 24" class="skill-icon" fill="currentColor"><path d="M3 3h18v18H3V3zm12.525 10.933c-.347-.54-.867-.84-1.44-.84-.533 0-.893.253-.893.68 0 .454.347.64 1.053.933 1.134.467 1.987.974 1.987 2.374 0 1.32-.987 2.187-2.507 2.187-1.547 0-2.453-.747-2.92-1.747l1.16-.68c.32.546.72.893 1.64.893.613 0 .96-.28.96-.787 0-.546-.44-.733-1.227-1.066-1.08-.453-1.813-.973-1.813-2.226 0-1.16.92-2.027 2.293-2.027 1.254 0 2.094.56 2.547 1.4l-1.073.88zm-5.467 4.16c-.227.387-.56.587-1.12.587-.613 0-.933-.36-.933-1.213V11h1.413v6.333c0 .32.094.467.334.467.146 0 .253-.013.306-.04l-.013 1.133z"/></svg>
                <span>JavaScript</span>
              </div>
              <div class="skill-item-card">
                <svg viewBox="0 0 24 24" class="skill-icon" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="4" width="16" height="16" rx="2"></rect><rect x="9" y="9" width="6" height="6"></rect><path d="M9 1v3M15 1v3M9 20v3M15 20v3M20 9h3M20 15h3M1 9h3M1 15h3"/></svg>
                <span>MIPS</span>
              </div>
              <div class="skill-item-card">
                <svg viewBox="0 0 24 24" class="skill-icon" fill="currentColor"><path d="M19.143 14.11a12.87 12.87 0 0 0-3.327-7.235 15.023 15.023 0 0 0-2.88-2.427A1.56 1.56 0 0 0 12 4.14a1.56 1.56 0 0 0-.936.308 15.02 15.02 0 0 0-2.88 2.427 12.872 12.872 0 0 0-3.327 7.235c-.15 1.173.543 2.126 1.59 2.593 1.637.73 3.6 1.297 5.553 1.297s3.916-.567 5.553-1.297c1.047-.467 1.74-1.42 1.59-2.593zm-7.143 1.89a4 4 0 1 1 4-4 4 4 0 0 1-4 4z"/></svg>
                <span>Astro</span>
              </div>
              <div class="skill-item-card">
                <svg viewBox="0 0 24 24" class="skill-icon" fill="currentColor"><path d="M24 11.25c0-1-.38-1.89-1-2.53a4.28 4.28 0 0 0-2.92-1.12A13.26 13.26 0 0 0 13.11 9 16.51 16.51 0 0 0 12 4.1a3.86 3.86 0 0 0-1-2.4A2.66 2.66 0 0 0 9 1a2.76 2.76 0 0 0-2.07.9A4 4 0 0 0 6 4.3a17.48 17.48 0 0 0 1.2 5A13.59 13.59 0 0 0 1.1 11.9c-.7.62-1.1 1.44-1.1 2.35A2.7 2.7 0 0 0 2.8 17a4.42 4.42 0 0 0 3-.92A13.26 13.26 0 0 0 10.89 15a16.51 16.51 0 0 0 1.11 4.9a3.86 3.86 0 0 0 1 2.4A2.66 2.66 0 0 0 15 23a2.76 2.76 0 0 0 2.07-.9a4 4 0 0 0 .93-2.4 17.48 17.48 0 0 0-1.2-5A13.59 13.59 0 0 0 22.9 12.1c.7-.62 1.1-1.44 1.1-2.35zm-12 3c-1.24 0-2.25-1-2.25-2.25S10.76 9.75 12 9.75s2.25 1 2.25 2.25-1.01 2.25-2.25 2.25z"/></svg>
                <span>React</span>
              </div>
              <div class="skill-item-card">
                <svg viewBox="0 0 24 24" class="skill-icon" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm4.5 13.5l-4.14-5.52v5.52H11v-7h1.36l4.14 5.52v-5.52H17.5v7h-1z"/></svg>
                <span>Next.js</span>
              </div>
              <div class="skill-item-card">
                <svg viewBox="0 0 24 24" class="skill-icon" fill="currentColor"><path d="M3 3h18v18H3V3zm11.235 7.734h-1.921v7.654h-1.428v-7.654H8.966V9.458h5.269v1.734zm4.184 4.542c0 2.374-2.147 3.254-4.522 3.254-1.127 0-2.247-.28-2.913-.747l.553-1.427c.567.387 1.407.687 2.267.687 1.34 0 2.147-.507 2.147-1.454 0-.906-.687-1.273-1.967-1.733-1.54-.547-2.613-1.314-2.613-3.007 0-1.894 1.68-2.987 3.993-2.987.98 0 1.907.214 2.507.547l-.507 1.393c-.42-.24-.107-.467-1.88-.467-1.14 0-1.727.467-1.727 1.18 0 .807.633 1.127 1.94 1.6 1.62.58 2.667 1.253 2.667 2.974z"/></svg>
                <span>TypeScript</span>
              </div>
              <div class="skill-item-card">
                <svg viewBox="0 0 24 24" class="skill-icon" fill="currentColor"><path d="M1.5 22L3.31 1.76h17.38L22.5 22 12 24.91zM18.82 4.95H5.18l1.17 13.09 5.65 1.56 5.65-1.56zm-3.1 4.5H9.68l.18 2.05h5.72l-.37 4.14-3.21.87-3.22-.87-.21-2.3H6.5l.39 4.38 5.11 1.41 5.11-1.41z"/></svg>
                <span>HTML</span>
              </div>
              <div class="skill-item-card">
                <svg viewBox="0 0 24 24" class="skill-icon" fill="currentColor"><path d="M12 2C6.48 2 2 3.79 2 6v12c0 2.21 4.48 4 10 4s10-1.79 10-4V6c0-2.21-4.48-4-10-4zm0 2c3.73 0 7.37 1.01 8 2-.63.99-4.27 2-8 2s-7.37-1.01-8-2c.63-.99 4.27-2 8-2zm8 8c0 .73-.84 1.4-2.24 1.92A13.42 13.42 0 0 1 12 15a13.42 13.42 0 0 1-5.76-1.08C4.84 13.4 4 12.73 4 12V8.33c1.47 1.05 4.54 1.67 8 1.67s6.53-.62 8-1.67V12zm0 6c0 .73-.84 1.4-2.24 1.92A13.42 13.42 0 0 1 12 21a13.42 13.42 0 0 1-5.76-1.08C4.84 19.4 4 18.73 4 18v-3.67c1.47 1.05 4.54 1.67 8 1.67s6.53-.62 8-1.67V18z"/></svg>
                <span>SQLite</span>
              </div>
              <div class="skill-item-card">
                <svg viewBox="0 0 24 24" class="skill-icon" fill="currentColor"><path d="M1.5 22L3.31 1.76h17.38L22.5 22 12 24.91zM18.82 4.95H5.18l1.17 13.09 5.65 1.56 5.65-1.56zm-3.23 3.61H8.38l.18 2.05h6.86l-.37 4.14-3.21.87-3.22-.87-.21-2.3H6.38l.39 4.38 5.11 1.41 5.11-1.41z"/></svg>
                <span>CSS</span>
              </div>
              <div class="skill-item-card">
                <svg viewBox="0 0 24 24" class="skill-icon" fill="currentColor"><path d="M23.953 12.556a.434.434 0 0 0-.156-.328l-4.147-3.11-.002-.001-4.062-3.047a.44.44 0 0 0-.523 0l-1.037.778-1.033-.778a.44.44 0 0 0-.523 0L8.413 6.07 7.376 5.292a.44.44 0 0 0-.523 0L2.791 9.118l-4.147 3.11a.433.433 0 0 0-.156.328.435.435 0 0 0 .159.324l11.666 8.744a.438.438 0 0 0 .526 0l11.666-8.744a.435.435 0 0 0 .159-.324z"/></svg>
                <span>GitLab</span>
              </div>
              <div class="skill-item-card">
                <svg viewBox="0 0 24 24" class="skill-icon" fill="currentColor"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12z"/></svg>
                <span>GitHub</span>
              </div>
            </div>

            <hr style="margin: 1.5rem 0; border: 0; border-top: 1px solid rgba(255,255,255,0.1);" />
            <h3 id="contact-heading">{t.contactHeading}</h3>
            
            <form id="portfolio-contact-form" class="contact-form" action="https://api.web3forms.com/submit" method="POST">
              <input type="hidden" name="access_key" value="YOUR_ACCESS_KEY_HERE" />
              <input type="checkbox" name="botcheck" class="hidden-honeypot" style="display: none;" />

              <div class="form-row">
                <div class="form-group">
                  <label for="contact-name" id="label-name">{t.lblName}</label>
                  <input type="text" id="contact-name" name="name" placeholder={t.phName} required />
                </div>
                <div class="form-group">
                  <label for="contact-email" id="label-email">{t.lblEmail}</label>
                  <input type="email" id="contact-email" name="email" placeholder={t.phEmail} required />
                </div>
              </div>

              <div class="form-group">
                <label for="contact-message" id="label-message">{t.lblMessage}</label>
                <textarea id="contact-message" name="message" rows="5" placeholder={t.phMessage} required></textarea>
              </div>

              <button type="submit" id="contact-submit-btn" class="form-submit-btn">{t.btnSubmit}</button>
              
              <div id="form-feedback-message" class="form-feedback"></div>
            </form>

            <p style="margin-top: 1.5rem; margin-bottom: 0;">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: middle; margin-right: 6px; color: #a855f7;">
                <path d="M22 13V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v7"></path>
                <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
                <path d="M2 17a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-4H2z"></path>
              </svg>
              <a href="mailto:infelixursus@gmail.com" class="contact-link">infelixursus@gmail.com</a>
              <br /><br />
              🔗&nbsp;<a href="https://github.com/InfelixUrsus" target="_blank" rel="noopener noreferrer" class="contact-link">github.com/InfelixUrsus</a>
            </p>
          </div>
          <p class="subtitle" id="portfolio-architecture-subtitle">{t.archSubtitle}</p>
        </div>
      </section>

      <section class="screen-view">
        <div class="content-wrapper">
          <h2 class="section-title" id="showcase-heading">{t.showcaseHeading}</h2>
          <p class="subtitle" id="showcase-subtitle">{t.showcaseSubtitle}</p>
          
          <div class="projects-grid">
            <a href="/examples/doctor" class="project-card-link">
              <div class="project-card featured-card">
                <span class="live-badge" id="preview-badge-text">{t.previewBadge}</span>
                <h3 id="mockup-card-title">{t.mockupTitle}</h3>
                <p id="mockup-card-desc">{t.mockupDesc}</p>
                <div class="tech-tags">
                  <span class="tag">Astro</span>
                  <span class="tag" id="tag-biomed">{t.tagBiomed}</span>
                  <span class="tag" id="tag-light">{t.tagLight}</span>
                </div>
              </div>
            </a>

            {localProjects.map((project) => (
              <div class="project-card">
                <h3>{project.data.title}</h3>
                <p>{project.data.description}</p>
                <div class="tech-tags">
                  {project.data.technologies?.map((tech) => (<span class="tag">{tech}</span>))}
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>

    </div>
  </div>

  <script>
    import '../scripts/portofolio_slider.ts';
    import { globalTranslations } from '../utils/translations';

    const langBtn = document.getElementById('global-lang-btn');
    
    function syncFormRuntimeLanguage() {
      if (!langBtn) return;
      
      const activeLang = langBtn.textContent?.trim() === "English" ? "el" : "en";
      const strings = globalTranslations[activeLang];

      if (!strings) return;

      // DOM Text Assignments
      const heading = document.getElementById('contact-heading');
      const skillsHeading = document.getElementById('skills-heading');
      const lblName = document.getElementById('label-name');
      const lblEmail = document.getElementById('label-email');
      const lblMessage = document.getElementById('label-message');
      const submitBtn = document.getElementById('contact-submit-btn');

      if (heading) heading.textContent = strings.contactHeading;
      if (skillsHeading) skillsHeading.textContent = strings.skillsHeading;
      if (lblName) lblName.textContent = strings.lblName;
      if (lblEmail) lblEmail.textContent = strings.lblEmail;
      if (lblMessage) lblMessage.textContent = strings.lblMessage;
      if (submitBtn) submitBtn.textContent = strings.btnSubmit;

      // Input Attribute Sync
      const nameInput = document.getElementById('contact-name') as HTMLInputElement;
      const emailInput = document.getElementById('contact-email') as HTMLInputElement;
      const messageInput = document.getElementById('contact-message') as HTMLTextAreaElement;

      if (nameInput) nameInput.placeholder = strings.phName;
      if (emailInput) emailInput.placeholder = strings.phEmail;
      if (messageInput) messageInput.placeholder = strings.phMessage;
    }

    langBtn?.addEventListener('click', () => {
      setTimeout(syncFormRuntimeLanguage, 20);
    });

    syncFormRuntimeLanguage();

    const contactForm = document.getElementById('portfolio-contact-form') as HTMLFormElement;
    const feedbackMsg = document.getElementById('form-feedback-message');
    
    contactForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!feedbackMsg) return;

      const activeLang = langBtn?.textContent?.trim() === "English" ? "el" : "en";
      
      const statusText = {
        en: { sending: "Sending message...", success: "Message sent successfully!", error: "Something went wrong. Please try again." },
        el: { sending: "Αποστολή μηνύματος...", success: "Το μήνυμα στάλθηκε επιτυχώς!", error: "Κάτι πήγε στραβά. Παρακαλώ δοκιμάστε ξανά." }
      }[activeLang];

      feedbackMsg.textContent = statusText.sending;
      feedbackMsg.className = "form-feedback feedback-processing";

      const formData = new FormData(contactForm);

      try {
        const response = await fetch(contactForm.action, {
          method: 'POST',
          body: formData,
          headers: { 'Accept': 'application/json' }
        });

        if (response.ok) {
          feedbackMsg.textContent = statusText.success;
          feedbackMsg.className = "form-feedback feedback-success";
          contactForm.reset();
        } else {
          throw new Error('Form execution failure');
        }
      } catch (err) {
        feedbackMsg.textContent = statusText.error;
        feedbackMsg.className = "form-feedback feedback-error";
      }
    });
  </script>
</Layout>

<style>
  .form-feedback {
    display: none;
    font-size: 0.9rem;
    font-weight: 500;
    padding: 0.75rem 1rem;
    border-radius: 8px;
    margin-top: 0.5rem;
    text-align: center;
    width: 100%;
    box-sizing: border-box;
  }
  
  .feedback-processing {
    display: block;
    background-color: rgba(255, 255, 255, 0.05);
    color: #cbd5e1;
